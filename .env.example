# Database - Neon PostgreSQL
# Pooled connection (for app runtime - shorter queries)
DATABASE_URL="postgresql://[user]:[password]@[host-pooler].[region].aws.neon.tech/[database]?sslmode=require"

# Unpooled connection (for migrations, seeds, Better Auth - critical for session persistence)
DATABASE_URL_UNPOOLED="postgresql://[user]:[password]@[host].[region].aws.neon.tech/[database]?sslmode=require"

# Alternative naming (used by Drizzle/Prisma)
DIRECT_URL="postgresql://[user]:[password]@[host].[region].aws.neon.tech/[database]?sslmode=require"

# Authentication
BETTER_AUTH_SECRET="your-32-byte-base64-secret"
BETTER_AUTH_URL="http://localhost:3000"

# Stripe (Test Mode)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_SECRET_KEY="sk_test_..."

# M-PESA (Daraja API - Test)
MPESA_CONSUMER_KEY="your_key"
MPESA_CONSUMER_SECRET="your_secret"
MPESA_PASSKEY="your_passkey"
MPESA_BUSINESS_SHORT_CODE="174379"
MPESA_CALLBACK_URL="http://localhost:3000/api/payments/mpesa/callback"

# Cloudinary
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your_cloud_name"
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET="your_upload_preset"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"